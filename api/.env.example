# Stack: Database+Auth=Supabase free tier, Embeddings+LLM=Ollama on Mac (no Docker), API=run locally.
# === Database (Supabase PostgreSQL) ===
# IMPORTANT: Use the "Connection pooling" URI (port 6543), not the direct one (5432).
# Direct connection often fails with EHOSTUNREACH (IPv6). Pooler works reliably.
# Supabase Dashboard → Project Settings → Database → Connection string → Connection pooling → URI
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# === Supabase keys (for future auth/storage) ===
# Get from: supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
EMAIL_VERIFICATION_REDIRECT_URL=ohm://verify-email
INTERNAL_METRICS_KEY=replace-with-long-random-internal-dashboard-key

# === API server ===
PORT=3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# === Email verification ===
# Supabase Auth sends verification email. Add EMAIL_VERIFICATION_REDIRECT_URL
# to Supabase Auth -> URL Configuration -> Redirect URLs.

# === Ollama (on your Mac directly, no Docker — install from ollama.com) ===
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# === Image generation (fal.ai) ===
# Get key from: fal.ai/dashboard
FAL_KEY=

# === ML service ===
ML_SERVICE_URL=http://localhost:8000
