{
  "expo": {
    "name": "ohm.",
    "slug": "ohm-app",
    "version": "1.0.0",
    "scheme": "ohm",
    "orientation": "portrait",
    "icon": "./assets/images/ohm-logo.png",
    "splash": {
      "backgroundColor": "#F5F0EA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ohm.app"
    },
    "android": {
      "package": "com.ohm.app",
      "adaptiveIcon": {
        "backgroundColor": "#F5F0EA"
      }
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
