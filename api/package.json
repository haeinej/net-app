{
  "name": "net-api",
  "version": "1.0.0",
  "scripts": {
    "dev": "node --dns-result-order=ipv4first node_modules/.bin/tsx watch src/index.ts",
    "build": "tsc",
    "start": "node --dns-result-order=ipv4first dist/index.js",
    "db:migrate": "node --dns-result-order=ipv4first -r tsx/cjs src/db/migrate.ts",
    "db:ping": "node --dns-result-order=ipv4first -r tsx/cjs scripts/ping-db.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "learning:daily": "tsx src/learning/cron.ts daily",
    "learning:weekly": "tsx src/learning/cron.ts weekly"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/websocket": "^11.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "pg": "^8.13.0",
    "postgres": "^3.4.5",
    "dotenv": "^16.4.0",
    "zod": "^3.23.0",
    "drizzle-orm": "^0.38.0",
    "@fal-ai/client": "^1.2.0"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.700.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
