# === Database (Supabase PostgreSQL) ===
# Get from: supabase.com/dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# === Supabase keys (for future auth/storage) ===
# Get from: supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === API server ===
PORT=3000
JWT_SECRET=change-me-in-production

# === Ollama (runs as Mac app — install from ollama.com) ===
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# === Image generation (fal.ai) ===
# Get key from: fal.ai/dashboard
FAL_KEY=

# === ML service ===
ML_SERVICE_URL=http://localhost:8000
