{
  "expo": {
    "name": "ohm.",
    "slug": "ohm-app",
    "version": "1.0.0",
    "description": "Share one thought at a time and let it open private conversations.",
    "scheme": "ohm",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/ohm-app-icon.png",
    "splash": {
      "backgroundColor": "#F5F0EA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ohmmmm.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSPhotoLibraryUsageDescription": "Allow ohm. to access your photos so you can choose a profile or thought image.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ohmmmm.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ohm-app-icon.png",
        "backgroundColor": "#F5F0EA"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ohm. to access your photos so you can choose a profile or thought image."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8954382e-1e4f-4137-8714-9890844f9dcd"
      }
    },
    "owner": "haeinej"
  }
}
